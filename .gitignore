# ==================== Forensic Evidence Protection ====================
# NEVER COMMIT REAL EVIDENCE FILES
# These patterns ensure forensic evidence is never accidentally committed

# Evidence directories
/evidence/
/case_files/
/chain_of_custody_logs/

# Forensic images
*.E01
*.dd
*.raw
*.aff

# Memory dumps
*.mem
*.dmp

# Network captures
*.pcap
*.pcapng

# Mobile device backups
*.backup
*.ab

# Password files
*pass*
*password*
*credential*
*secret*

# Personal data
*personal*
*private*
*confidential*

# Create a personal .gitignore.local for user-specific ignores
cat > .gitignore.local << 'EOF'
# User-specific ignores
personal_notes.md
experimental/
test_data/
local_config.yaml
EOF

# Add to main .gitignore
echo "\n# Local overrides" >> .gitignore
echo ".gitignore.local" >> .gitignore

# Install git-lfs
# Track large binary files
git lfs track "*.jpg"
git lfs track "*.png"
git lfs track "*.pth"
git lfs track "*.h5"

# Add to .gitattributes
echo "*.jpg filter=lfs diff=lfs merge=lfs -text" >> .gitattributes
echo "*.png filter=lfs diff=lfs merge=lfs -text" >> .gitattributes
echo "*.pth filter=lfs diff=lfs merge=lfs -text" >> .gitattributes