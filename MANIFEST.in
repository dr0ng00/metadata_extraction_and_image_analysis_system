# Include README
include README.md
include LICENSE
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md

# Include requirements
include requirements.txt
include requirements-dev.txt

# Include configuration files
recursive-include config *.yaml
recursive-include config *.yml
recursive-include config *.json

# Include documentation
recursive-include docs *.md
recursive-include docs *.rst
recursive-include docs *.txt
recursive-include docs Makefile

# Include examples
recursive-include examples *.jpg
recursive-include examples *.png
recursive-include examples *.json

# Include scripts
include scripts/*.py
include scripts/*.sh

# Include tests
recursive-include tests *.py
recursive-include tests *.json
recursive-include tests *.yaml

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude Thumbs.db
global-exclude *.swp
global-exclude *.swo
global-exclude .git
global-exclude .hg
global-exclude .svn

# Exclude build and distribution directories
prune build
prune dist
prune *.egg-info

# Exclude forensic workspace
prune forensic_workspace
prune results
prune evidence
prune datasets